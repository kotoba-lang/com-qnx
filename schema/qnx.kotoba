// Qnx clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace qnx {

    entity Process {
        id: string @unique
        pid: integer
        command: string
        state: string
        uid: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Thread {
        id: string @unique
        pid: integer
        tid: integer
        state: string
        priority: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity FileDescriptor {
        id: string @unique
        pid: integer
        fd: integer
        path: string
        mode: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Syscall {
        id: string @unique
        name: string
        number: integer
        argCount: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity MemoryRegion {
        id: string @unique
        pid: integer
        startAddr: string
        sizeBytes: integer
        perms: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Signal {
        id: string @unique
        pid: integer
        number: integer
        action: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
